# Custom components configuration example for L2J game server.

# Enable custom spawnlist table.
# Default: False
L2JGAME_general_CustomSpawnlistTable = False

# Option to save GM spawn only in the custom table.
# Default: False
L2JGAME_general_SaveGmSpawnOnCustom = False

# Enable custom NPC data.
# Default: False
L2JGAME_general_CustomNpcData = False

# Enable custom teleport data.
# Default: False
L2JGAME_general_CustomTeleportTable = False

# Enable custom NPC buffer tables.
# Default: False
L2JGAME_general_CustomNpcBufferTables = False

# Enable custom skills load.
# Default: False
L2JGAME_general_CustomSkillsLoad = False

# Enable custom items load.
# Default: False
L2JGAME_general_CustomItemsLoad = False

# Enable custom multisell load.
# Default: False
L2JGAME_general_CustomMultisellLoad = False

# Enable custom buylist load.
# Default: False
L2JGAME_general_CustomBuyListLoad = False