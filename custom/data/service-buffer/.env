# Service Buffer configuration example for L2J game server.

# Enable the buffer service NPC.
# Default: False
L2JGAME_bufferservice_Enable=True

# Allow voiced command .bufferservice
# Default: False
L2JGAME_bufferservice_VoicedEnable=True

# Seconds between heal uses on the buffer NPC.
# Default: 60
L2JGAME_bufferservice_HealCooldown=60

# Max saved buff lists per player.
# Default: 5
L2JGAME_bufferservice_MaxUniqueLists=5

# Required for buffer service NPC tables to load.
# Default: False
L2JGAME_general_CustomNpcBufferTables=False
