# Rates configuration for L2J game server.

# XP rate affects all experience gains.
# Default: 1
L2JGAME_rates_RateXp=1

# SP rate affects skill point gains from leveling.
# Default: 1
L2JGAME_rates_RateSp=1

# Party XP and SP rates apply when players are in a party.
# Default: 1.0
L2JGAME_rates_RatePartyXp=1.0
L2JGAME_rates_RatePartySp=1.0

# Pet XP rate controls how quickly pets level up.
# Default: 1
L2JGAME_rates_PetXpRate=1
