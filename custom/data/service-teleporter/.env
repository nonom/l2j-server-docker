# Service Teleporter configuration example for L2J game server.

# Enable/Disable TeleporterService
# Default: False
L2JGAME_teleporterservice_Enable=False

# Enable/Disable voiced teleporter
# Default: False
L2JGAME_teleporterservice_VoicedEnable=False

# The voiced command for the voiced teleporter
# Default: teleporterservice
L2JGAME_teleporterservice_VoicedCommand=teleporterservice

# The name of the voiced teleporter
# Default: Voiced
L2JGAME_teleporterservice_VoicedName=Voiced

# Item id required to be in the inventory to be able to use the voiced teleporter
# 0 = no item required
# Default: 0
L2JGAME_teleporterservice_VoicedRequiredItem=0