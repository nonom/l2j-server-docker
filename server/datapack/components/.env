# Custom components configuration example for L2J game server.

# Enable custom spawnlist table.
# Default: False
L2JGAME_general_CustomSpawnlistTable = True

# Option to save GM spawn only in the custom table.
# Default: False
L2JGAME_general_SaveGmSpawnOnCustom = True

# Enable custom NPC data.
# Default: False
L2JGAME_general_CustomNpcData = True

# Enable custom teleport data.
# Default: False
L2JGAME_general_CustomTeleportTable = True

# Enable custom NPC buffer tables.
# Default: False
L2JGAME_general_CustomNpcBufferTables = True

# Enable custom skills load.
# Default: False
L2JGAME_general_CustomSkillsLoad = True

# Enable custom items load.
# Default: False
L2JGAME_general_CustomItemsLoad = True

# Enable custom multisell load.
# Default: False
L2JGAME_general_CustomMultisellLoad = True

# Enable custom buylist load.
# Default: False
L2JGAME_general_CustomBuyListLoad = True