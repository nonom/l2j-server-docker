# Logs configuration for L2J game server.

# This will increase writing to your hard drive considerably.

# Default: False
L2JGAME_general_LogChat=False

# Default: False
L2JGAME_general_LogAutoAnnouncements=False

# Default: False
L2JGAME_general_LogItems=False

# Log only Adena and equippable items if LogItems is enabled
L2JGAME_general_LogItemsSmallLog=False

# Default: False
L2JGAME_general_LogItemEnchants=False

# Default: False
L2JGAME_general_LogSkillEnchants=False

# Default: False
L2JGAME_general_GMAudit=False

# Show quests while loading them.
# Default: False
L2JGAME_general_ShowQuestsLoadInLogs=False

# Show scripts while loading them.
# Default: False
L2JGAME_general_ShowScriptsLoadInLogs=False

# Log all Olympiad fights and outcome to olympiad.csv file.
# Default: False
L2JGAME_olympiad_LogFights=False

# UseItem - item usage flooding
L2JGAME_floodprotector_UseItemLogFlooding=False

# RollDice - rolling dice flooding
L2JGAME_floodprotector_RollDiceLogFlooding=False

# Firework - firework flooding
L2JGAME_floodprotector_FireworkLogFlooding=False

# ItemPetSummon - item summoning and pet mounting flooding
L2JGAME_floodprotector_ItemPetSummonLogFlooding=False

# HeroVoice - hero voice flooding
L2JGAME_floodprotector_HeroVoiceLogFlooding=False

# GlobalChat - global chat flooding
L2JGAME_floodprotector_GlobalChatLogFlooding=False

# Subclass - subclass flooding
L2JGAME_floodprotector_SubclassLogFlooding=False

# DropItem - drop item flooding
L2JGAME_floodprotector_DropItemLogFlooding=False

# ServerBypass - server bypass flooding
L2JGAME_floodprotector_ServerBypassLogFlooding=False

# ServerBypass - multisell list request flooding
L2JGAME_floodprotector_MultiSellLogFlooding=False

# All kinds of other transactions - to/from pet, private store, warehouse, destroy
L2JGAME_floodprotector_TransactionLogFlooding=False

# Manufacture
L2JGAME_floodprotector_ManufactureLogFlooding=False

# Manor
L2JGAME_floodprotector_ManorLogFlooding=False

# SendMail - sending mail interval, 10s on retail
L2JGAME_floodprotector_SendMailLogFlooding=False

# CharacterSelect - attempts to load character
L2JGAME_floodprotector_CharacterSelectLogFlooding=False

# Item Auction - Request for refresh
L2JGAME_floodprotector_ItemAuctionLogFlooding=False
